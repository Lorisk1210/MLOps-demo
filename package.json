{
  "name": "mlops-demo",
  "private": true,
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev:backend": "bun --watch backend/server.js",
    "dev:frontend": "bun run --cwd frontend dev",
    "start:backend": "bun backend/server.js",
    "build:frontend": "bun run --cwd frontend build",
    "test:unit": "vitest run",
    "test:eval:regression": "node scripts/run-promptfoo-suite.mjs regression evals/promptfooconfig.regression.mjs 0.9 0",
    "test:eval:hallucination": "node scripts/run-promptfoo-suite.mjs hallucination evals/promptfooconfig.hallucination.mjs 0.9 0",
    "test:eval:prompt_injection": "node scripts/run-promptfoo-suite.mjs prompt_injection evals/promptfooconfig.prompt_injection.mjs 1 0",
    "test:eval:metamorphic_bias": "node scripts/run-promptfoo-suite.mjs metamorphic_bias evals/promptfooconfig.metamorphic_bias.mjs 1 0",
    "test:eval": "bun run test:eval:regression || true; bun run test:eval:hallucination || true; bun run test:eval:prompt_injection || true; bun run test:eval:metamorphic_bias || true",
    "summarize": "node scripts/summarize-results.mjs",
    "test:ci": "bun run build:frontend && bun run test:unit && bun run test:eval && bun run summarize"
  },
  "devDependencies": {
    "promptfoo": "^0.121.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3"
  }
}
