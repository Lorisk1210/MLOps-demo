# Required: OpenRouter API key (free tier works)
OPENROUTER_API_KEY=sk-or-v1-...

# Subject model: the LLM under test (the course assistant itself)
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Judge model: used by LLM-as-judge assertions (hallucination, semantic equivalence).
# Must differ from OPENROUTER_MODEL — evals/judge.mjs throws if they match.
OPENROUTER_MODEL2=google/gemma-4-26b-a4b-it:free

# Optional: enable promptfoo's disk cache for faster reruns on identical inputs
PROMPTFOO_CACHE_ENABLED=true
